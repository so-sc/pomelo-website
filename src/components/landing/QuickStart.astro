---
const steps = [
  {
    num: "01",
    title: "Run the installer",
    desc: "Requires a Linux host. The script installs Docker if missing, pulls all images, and writes a default .env.",
    cmd: "curl -fsSL pomelo.sosc.org.in/install.sh | sudo bash",
  },
  {
    num: "02",
    title: "Start Pomelo",
    desc: "The CLI brings up all services, including the API server, judge worker, and frontend. Open Web UI when healthy.",
    cmd: "pomelo start",
  },
];
---

<section class="qs">
  <div class="section-inner">
    <div class="section-header">
      <h2 class="section-title">Up and running in under five minutes.</h2>
      <p class="section-sub">Two commands. Requires Linux. No account or API key needed to get started.</p>
    </div>

    <ol class="qs-list">
      {steps.map(({ num, title, desc, cmd }) => (
        <li class="qs-item">
          <div class="qs-num">{num}</div>
          <div class="qs-content">
            <h3>{title}</h3>
            <p>{desc}</p>
            <div class="qs-cmd"><code>{cmd}</code></div>
          </div>
        </li>
      ))}
    </ol>

    <div class="qs-cta">
      <a href="/docs" class="qs-link-btn">Full installation guide &rarr;</a>
      <a href="/docs#troubleshooting" class="qs-link-plain">Troubleshooting</a>
    </div>
  </div>
</section>

<style>
  .qs { border-top: 1px solid hsl(var(--border)); }

  .section-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  .section-header { margin-bottom: 1.5rem; }

  .section-title {
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: hsl(var(--foreground));
    margin: 0 0 0.4rem;
  }

  .section-sub {
    font-size: 0.85rem;
    color: hsl(var(--muted-foreground));
    line-height: 1.6;
    margin: 0;
  }

  .qs-list {
    list-style: none;
    margin: 0 0 0 1rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    border-left: 1px solid hsl(var(--border));
  }

  .qs-item {
    display: flex;
    gap: 1.5rem;
    padding: 0 0 1.75rem 1.75rem;
    position: relative;
  }
  .qs-item:last-child { padding-bottom: 0; }

  .qs-item::before {
    content: '';
    position: absolute;
    left: -0.4rem;
    top: 0.35rem;
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 50%;
    background: hsl(var(--background));
    border: 1.5px solid hsl(var(--primary));
  }

  .qs-num {
    font-family: var(--font-mono, monospace);
    font-size: 0.68rem;
    font-weight: 700;
    color: hsl(var(--primary));
    letter-spacing: 0.08em;
    flex-shrink: 0;
    padding-top: 0.2rem;
    min-width: 1.5rem;
  }

  .qs-content { flex: 1; }

  .qs-content h3 {
    font-size: 0.875rem;
    font-weight: 600;
    color: hsl(var(--foreground));
    margin: 0 0 0.3rem;
    letter-spacing: -0.01em;
  }

  .qs-content p {
    font-size: 0.8rem;
    color: hsl(var(--muted-foreground));
    line-height: 1.6;
    margin: 0 0 0.75rem;
  }

  .qs-cmd {
    display: inline-flex;
    border: 1px solid hsl(var(--border));
    border-radius: 0.4rem;
    background: hsl(var(--muted) / 0.4);
    padding: 0.38rem 0.75rem;
  }

  .qs-cmd code {
    font-family: var(--font-mono, monospace);
    font-size: 0.75rem;
    color: hsl(var(--foreground));
    white-space: nowrap;
  }

  .qs-cta {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .qs-link-btn {
    font-size: 0.82rem;
    font-weight: 600;
    color: hsl(var(--primary));
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .qs-link-btn:hover { opacity: 0.8; }

  .qs-link-plain {
    font-size: 0.82rem;
    color: hsl(var(--muted-foreground));
    text-decoration: none;
    transition: color 0.15s;
  }
  .qs-link-plain:hover { color: hsl(var(--foreground)); }

  @media (max-width: 860px) {
    .section-inner { padding: 2rem 1.25rem; }
    .qs-cmd code { white-space: normal; word-break: break-all; }
    .qs-cmd { display: flex; width: 100%; box-sizing: border-box; }
  }
  @media (max-width: 600px) {
    .section-inner { padding: 1.75rem 1rem; }
    .qs-list { margin-left: 0.75rem; }
    .qs-item { gap: 1rem; padding-left: 1.25rem; }
    .qs-cta { flex-direction: column; align-items: flex-start; gap: 0.75rem; }
  }
</style>
