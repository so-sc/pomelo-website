---
import CodeBlock from "./CodeBlock.astro";
import CmdBar from "./CmdBar.astro";
import Note from "./Note.astro";
import SectionLabel from "./SectionLabel.astro";

const CLONE_CMD = "git clone https://github.com/so-sc/pomelo && cd pomelo";
const INSTALL_CMD = "pnpm install";
const DEV_CMD = "pnpm dev";
const BUN_INSTALL_CMD = "curl -fsSL https://bun.sh/install | bash";
const ENV_CMD = "cp .env.example .env";
const DOCKER_CMD = `docker compose --project-name pomelo --env-file .env \\
  -f docker/app/docker-compose.dev.yaml \\
  -f docker/judge0/docker-compose.dev.yaml \\
  --project-directory . up mongo judge0-server judge0-workers seed -d`;

const prerequisites = [
  ["Node.js", "LTS", "Client and server packages"],
  ["pnpm", "10.0.0 or newer", "Workspace package manager"],
  ["Docker", "latest", "Running the full dev stack"],
  ["Docker Compose", "v2 or newer", "Orchestrating services"],
  ["Git", "latest", "Cloning the repository"],
  ["Bun", "latest", "Admin CLI and daemon tooling"],
];

const scripts = [
  ["pnpm dev", "Build code-gen and start Turborepo dev mode"],
  ["pnpm build", "Build all packages in the workspace"],
  ["pnpm test", "Run tests across all packages"],
  ["pnpm lint", "Lint all packages"],
  ["pnpm clean", "Remove build artifacts and node_modules"],
];

const endpoints = [
  ["Frontend", "http://localhost:3000"],
  ["Backend", "http://localhost:8080"],
  ["Judge0", "http://localhost:2358"],
];

const envVars = [
  ["AUTH_SECRET", "required", "Long random secret used by auth middleware. Required."],
  ["PORT", "8080", "Port the Express backend listens on."],
  ["MONGODB_URI", "mongodb://localhost:27017/pomelo", "MongoDB connection string used by the backend and admin tools."],
  ["JUDGE0_URL", "http://judge0-server:2358", "URL for the Judge0 code execution service."],
  ["DOMAIN", "localhost:3000", "Frontend domain used by the client."],
  ["PROTOCOL", "http", "Protocol for the frontend app."],
  ["BACKEND_URL", "http://localhost:8080", "URL used by server-side code to call the backend."],
  ["POSTGRES_PASSWORD", "required", "PostgreSQL password for Judge0 containers."],
  ["REDIS_PASSWORD", "required", "Redis password for Judge0 containers."],
];

const services = [
  { name: "mongo", port: "27017", desc: "MongoDB database for contest and user data." },
  { name: "server", port: "8080", desc: "Express API for auth, contests, and submissions." },
  { name: "client", port: "3000", desc: "Participant-facing web app." },
  { name: "seed", port: "", desc: "Seeds MongoDB with initial data, then exits." },
  { name: "judge0-server", port: "2358", desc: "Judge0 core server for code execution." },
  { name: "judge0-workers", port: "", desc: "Judge0 worker processes." },
  { name: "judge0-db", port: "", desc: "PostgreSQL for Judge0 internal state." },
  { name: "judge0-redis", port: "", desc: "Redis for Judge0 job queuing." },
];

const troubleshooting = [
  {
    problem: "pnpm install fails",
    check: "Toolchain",
    steps: [
      "Confirm pnpm 10.0.0 or newer is installed.",
      "Confirm Node.js is installed.",
      "Confirm Git is available in PATH.",
    ],
  },
  {
    problem: "pnpm dev fails",
    check: "Environment",
    steps: [
      "Confirm .env exists and matches .env.example.",
      "Confirm AUTH_SECRET is set to a non-empty value.",
      "Confirm MONGODB_URI points to a running MongoDB instance.",
      "Confirm JUDGE0_URL points to a running Judge0 server.",
    ],
  },
  {
    problem: "Docker Compose fails",
    check: "Containers",
    steps: [
      "Confirm Docker and Docker Compose v2 are installed.",
      "Confirm .env exists in the repository root.",
      "Confirm POSTGRES_PASSWORD and REDIS_PASSWORD are set.",
      "Run the Docker Compose command from the repo root directory.",
    ],
  },
  {
    problem: "Backend cannot connect to MongoDB",
    check: "Database",
    steps: [
      "Verify MONGODB_URI is correct and reachable.",
      "Confirm the mongo container or service is running.",
      "Check logs with docker logs pomelo-mongo-1.",
    ],
  },
  {
    problem: "Judge0 jobs fail or time out",
    check: "Judge0",
    steps: [
      "Verify JUDGE0_URL is correct.",
      "Confirm judge0-server and judge0-workers are running.",
      "Confirm judge0-db and judge0-redis are healthy.",
    ],
  },
];
---

<main class="min-w-0 flex-1 py-6 pl-0 md:pl-8">
  <div class="max-w-[75ch]">
    <section id="introduction" class="mb-12 scroll-mt-20">
      <h1 class="mb-6 text-4xl font-extrabold tracking-tight text-foreground">Pomelo</h1>
      <h2 class="mb-4 text-2xl font-bold text-foreground">What is Pomelo?</h2>
      <p class="mb-4 text-base leading-7 text-foreground">
        Pomelo is an open-source competitive programming contest platform for hosting coding contests with automated code evaluation powered by
        <a href="https://judge0.com" target="_blank" rel="noopener noreferrer" class="text-primary underline underline-offset-4 hover:no-underline">Judge0</a>.
      </p>
      <p class="mb-4 text-base leading-7 text-foreground">
        It provides the pieces needed to run a local contest environment, including a participant-facing web app, an Express API, admin tooling, and Docker services for the backing stack.
      </p>
      <p class="text-base leading-7 text-foreground">
        Use this documentation to install dependencies, configure environment variables, start the services, and troubleshoot setup issues.
      </p>
    </section>

    <section id="prerequisites" class="mb-12 scroll-mt-20">
      <SectionLabel>Getting Started</SectionLabel>
      <h2 class="mb-3 text-2xl font-bold text-foreground">Prerequisites</h2>
      <p class="mb-4 text-base leading-7 text-muted-foreground">
        Before setting up Pomelo, make sure the following tools are available on your system.
      </p>

      <div class="overflow-x-auto rounded-lg border border-border">
        <table class="w-full min-w-[34rem] text-sm">
          <thead>
            <tr class="border-b border-border bg-muted">
              <th class="px-3 py-2 text-left font-semibold text-foreground">Tool</th>
              <th class="px-3 py-2 text-left font-semibold text-foreground">Version</th>
              <th class="px-3 py-2 text-left font-semibold text-foreground">Required for</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            {prerequisites.map(([tool, version, use]) => (
              <tr class="bg-card">
                <td class="px-3 py-2.5 font-mono text-xs font-medium text-foreground">{tool}</td>
                <td class="px-3 py-2.5 font-mono text-xs text-muted-foreground">{version}</td>
                <td class="px-3 py-2.5 text-xs text-muted-foreground">{use}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <h3 class="mb-2 mt-6 text-base font-semibold text-foreground">Install Bun</h3>
      <p class="mb-2 text-sm leading-6 text-muted-foreground">
        The admin CLI and daemon in <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-[0.8em] text-foreground">admin/</code> require Bun.
      </p>
      <CmdBar cmd={BUN_INSTALL_CMD} />
      <p class="text-sm text-muted-foreground">
        After installing, reload your shell and verify with <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-[0.8em] text-foreground">bun --version</code>.
      </p>
    </section>

    <section id="installation" class="mb-12 scroll-mt-20">
      <SectionLabel>Getting Started</SectionLabel>
      <h2 class="mb-3 text-2xl font-bold text-foreground">Installation</h2>
      <p class="mb-4 text-base leading-7 text-muted-foreground">
        Clone the repository and install all workspace dependencies using <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-[0.8em] text-foreground">pnpm</code>.
      </p>

      <h3 class="mb-2 text-sm font-semibold text-foreground">Clone the repository</h3>
      <CmdBar cmd={CLONE_CMD} />

      <h3 class="mb-2 text-sm font-semibold text-foreground">Install dependencies</h3>
      <CmdBar cmd={INSTALL_CMD} />

      <Note>
        The repo uses <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-[0.8em] text-foreground">pnpm@10.33.0</code> as the package manager. Running npm install or yarn in this workspace is not supported.
      </Note>
    </section>

    <section id="quickstart" class="mb-12 scroll-mt-20">
      <SectionLabel>Getting Started</SectionLabel>
      <h2 class="mb-3 text-2xl font-bold text-foreground">Quick Start</h2>
      <p class="mb-4 text-base leading-7 text-muted-foreground">
        After installing dependencies and setting up your <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-[0.8em] text-foreground">.env</code> file, start the development stack.
      </p>

      <h3 class="mb-2 text-sm font-semibold text-foreground">Start all services</h3>
      <CmdBar cmd={DEV_CMD} />
      <p class="mb-4 text-sm leading-6 text-muted-foreground">
        This runs the root dev script, builds the code-gen package, then starts all workspace packages through Turborepo.
      </p>

      <h3 class="mb-2 text-sm font-semibold text-foreground">Available scripts</h3>
      <div class="space-y-3">
        {scripts.map(([cmd, desc]) => (
          <div>
            <p class="mb-1 text-xs text-muted-foreground">{desc}</p>
            <CmdBar cmd={cmd} />
          </div>
        ))}
      </div>

      <h3 class="mb-2 mt-6 text-sm font-semibold text-foreground">Verify the stack</h3>
      <p class="mb-2 text-sm text-muted-foreground">Once running, open these endpoints to confirm each service is up:</p>
      <div class="overflow-x-auto rounded-lg border border-border">
        <table class="w-full min-w-[28rem] text-sm">
          <thead>
            <tr class="border-b border-border bg-muted">
              <th class="px-3 py-2 text-left font-semibold text-foreground">Service</th>
              <th class="px-3 py-2 text-left font-semibold text-foreground">URL</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            {endpoints.map(([service, url]) => (
              <tr class="bg-card">
                <td class="px-3 py-2.5 text-xs text-foreground">{service}</td>
                <td class="px-3 py-2.5 font-mono text-xs text-primary">
                  <a href={url} target="_blank" rel="noopener noreferrer" class="hover:underline">{url}</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section id="environment" class="mb-12 scroll-mt-20">
      <SectionLabel>Configuration</SectionLabel>
      <h2 class="mb-3 text-2xl font-bold text-foreground">Environment Variables</h2>
      <p class="mb-3 text-base leading-7 text-muted-foreground">
        The repository ships with a single <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-[0.8em] text-foreground">.env.example</code> at the root. Copy it to <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-[0.8em] text-foreground">.env</code> before running anything.
      </p>
      <CmdBar cmd={ENV_CMD} />

      <CodeBlock
        filename=".env.example"
        language="bash"
        code={`# Shared secrets
AUTH_SECRET=xyz

# Backend server config
PORT=8080
MONGODB_URI=mongodb://localhost:27017/pomelo
JUDGE0_URL=http://judge0-server:2358

# Client config
DOMAIN=localhost:3000
PROTOCOL=http
BACKEND_URL=http://localhost:8080

# Judge0
POSTGRES_PASSWORD=judge0postgres123
REDIS_PASSWORD=judge0redis123`}
      />

      <h3 class="mb-3 mt-6 text-base font-semibold text-foreground">Variable reference</h3>
      <div class="overflow-x-auto rounded-lg border border-border">
        <table class="w-full min-w-[44rem] text-sm">
          <thead>
            <tr class="border-b border-border bg-muted">
              <th class="px-3 py-2 text-left font-semibold text-foreground">Variable</th>
              <th class="px-3 py-2 text-left font-semibold text-foreground">Default</th>
              <th class="px-3 py-2 text-left font-semibold text-foreground">Description</th>
            </tr>
          </thead>
          <tbody>
            {envVars.map(([name, def, desc]) => (
              <tr class="border-b border-border bg-card last:border-0">
                <td class="whitespace-nowrap px-3 py-2.5 font-mono text-xs font-medium text-primary">{name}</td>
                <td class="px-3 py-2.5 font-mono text-xs text-muted-foreground">{def}</td>
                <td class="px-3 py-2.5 text-xs text-muted-foreground">{desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <Note>
        There are no separate server or client env templates. The root <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-[0.8em] text-foreground">.env</code> is the single source of truth for the workspace.
      </Note>
    </section>

    <section id="docker" class="mb-12 scroll-mt-20">
      <SectionLabel>Configuration</SectionLabel>
      <h2 class="mb-3 text-2xl font-bold text-foreground">Docker Setup</h2>
      <p class="mb-3 text-base leading-7 text-muted-foreground">
        Pomelo includes Docker Compose definitions in <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-[0.8em] text-foreground">docker/app/</code> and <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-[0.8em] text-foreground">docker/judge0/</code>. Use the following command to start the backing services for local development.
      </p>

      <h3 class="mb-2 text-sm font-semibold text-foreground">Start the Docker dev stack</h3>
      <CodeBlock filename="terminal" language="bash" code={DOCKER_CMD} />

      <h3 class="mb-3 mt-6 text-base font-semibold text-foreground">Services</h3>
      <div class="space-y-2">
        {services.map((service) => (
          <div class="flex items-start gap-4 rounded-lg border border-border bg-card px-4 py-3">
            <code class="mt-0.5 shrink-0 rounded bg-primary/10 px-2 py-0.5 font-mono text-xs font-semibold text-primary">{service.name}</code>
            <div class="min-w-0 flex-1">
              <p class="text-xs text-muted-foreground">{service.desc}</p>
            </div>
            {service.port && <span class="shrink-0 font-mono text-xs text-muted-foreground">:{service.port}</span>}
          </div>
        ))}
      </div>

      <h3 class="mb-2 mt-6 text-sm font-semibold text-foreground">Stop containers</h3>
      <CmdBar cmd="docker compose --project-name pomelo down" />

      <h3 class="mb-2 text-sm font-semibold text-foreground">Remove volumes</h3>
      <CmdBar cmd="docker compose --project-name pomelo down -v" />
    </section>

    <section id="admin" class="mb-12 scroll-mt-20">
      <SectionLabel>Admin Tooling</SectionLabel>
      <h2 class="mb-3 text-2xl font-bold text-foreground">Bun CLI</h2>
      <p class="mb-3 text-base leading-7 text-muted-foreground">
        The admin directory contains two Bun-based tools:
      </p>
      <ul class="mb-4 space-y-2 text-sm text-muted-foreground">
        <li class="flex items-start gap-2">
          <span class="mt-1 shrink-0 text-primary">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </span>
          <span><code class="rounded bg-muted px-1.5 py-0.5 font-mono text-[0.8em] text-foreground">admin/src/pomelo.ts</code> - the CLI tool for managing contests</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="mt-1 shrink-0 text-primary">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"></polyline></svg>
          </span>
          <span><code class="rounded bg-muted px-1.5 py-0.5 font-mono text-[0.8em] text-foreground">admin/src/pomelod.ts</code> - the background daemon process</span>
        </li>
      </ul>
      <Note>
        Both files use Bun shebangs and require Bun to be installed. If Bun is missing, install it with <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-[0.8em] text-foreground">curl -fsSL https://bun.sh/install | bash</code>.
      </Note>
    </section>

    <section id="troubleshooting" class="mb-12 scroll-mt-20">
      <SectionLabel>Troubleshooting</SectionLabel>
      <h2 class="mb-3 text-2xl font-bold text-foreground">Common Issues</h2>
      <p class="mb-5 text-base leading-7 text-muted-foreground">
        Open the issue that matches what you are seeing, then compare the guidance with your local setup.
      </p>

      <div class="space-y-2">
        {troubleshooting.map((item) => (
          <details class="group rounded-lg border border-border bg-card">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-4 py-3 text-left sm:px-5">
              <span class="min-w-0">
                <span class="block font-mono text-[11px] font-semibold uppercase tracking-wider text-primary">{item.check}</span>
                <span class="mt-1 block text-sm font-semibold leading-5 text-foreground">{item.problem}</span>
              </span>
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md border border-border bg-muted text-muted-foreground transition-colors group-open:text-primary">
                <svg class="transition-transform group-open:rotate-180" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </span>
            </summary>
            <div class="space-y-3 border-t border-border px-4 py-4 sm:px-5">
              {item.steps.map((step) => (
                <p class="rounded-md bg-muted/40 px-3 py-2 text-sm leading-6 text-muted-foreground">
                  {step}
                </p>
              ))}
            </div>
          </details>
        ))}
      </div>
    </section>
  </div>
</main>
