---
import { getCollection } from 'astro:content';

const docs = await getCollection('docs');

interface SidebarLink {
  label: string;
  href: string;
  order: number;
}

interface SidebarSection {
  title: string;
  sectionOrder: number;
  links: SidebarLink[];
}

const sectionsMap = new Map<string, SidebarSection>();

for (const doc of docs) {
  const sectionTitle = doc.data.section;
  if (!sectionsMap.has(sectionTitle)) {
    sectionsMap.set(sectionTitle, { 
      title: sectionTitle, 
      sectionOrder: doc.data.sectionOrder, 
      links: [] 
    });
  }
  sectionsMap.get(sectionTitle)!.links.push({
    label: doc.data.title,
    href: `#${doc.id}`,
    order: doc.data.order
  });
}

const sidebarSections: SidebarSection[] = Array.from(sectionsMap.values())
  .sort((a, b) => a.sectionOrder - b.sectionOrder);

for (const section of sidebarSections) {
  section.links.sort((a, b) => a.order - b.order);
}
---

<aside class="sticky top-14 hidden h-[calc(100vh-3.5rem)] w-56 shrink-0 overflow-y-auto border-r border-border md:block">
  <div class="py-6 pr-4">
    {sidebarSections.map((section) => (
      <div class="mb-4">
        <p class="mb-1 px-3 text-xs font-semibold text-foreground">{section.title}</p>
        <ul>
          {section.links.map((link) => (
            <li>
              <a
                href={link.href}
                class="block rounded-md px-3 py-1 text-sm text-muted-foreground hover:bg-muted hover:text-foreground"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</aside>
