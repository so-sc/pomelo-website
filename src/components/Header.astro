---
import Logo from "@/components/ui/Logo.astro";
import ThemeToggle from "@/components/ui/ThemeToggle.astro";
---

<header class="sticky top-0 z-50 h-14 w-full border-b border-border bg-navbar-background/95 backdrop-blur-md">
  <div class="mx-auto flex h-full max-w-[90rem] items-center justify-between px-4">
    <div class="flex min-w-0 items-center gap-6">
      <Logo />

      <nav class="hidden items-center gap-6 md:flex" aria-label="Main navigation">
        <a href="#introduction" class="text-sm font-medium text-muted-foreground transition-colors hover:text-foreground">
          Docs
        </a>
        <a href="#docker" class="text-sm font-medium text-muted-foreground transition-colors hover:text-foreground">
          Docker
        </a>
        <a href="#troubleshooting" class="text-sm font-medium text-muted-foreground transition-colors hover:text-foreground">
          Troubleshooting
        </a>
        <a href="https://github.com/so-sc/pomelo/releases" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-muted-foreground transition-colors hover:text-foreground">
          Changelog
        </a>
      </nav>
    </div>

    <div class="flex items-center gap-3.5">
      <button
        id="docs-search-trigger"
        type="button"
        class="hidden h-8 min-w-0 items-center gap-2 rounded-md border border-border bg-muted/40 px-2.5 text-xs text-muted-foreground transition-colors hover:bg-muted sm:flex"
        aria-label="Open documentation search"
      >
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 opacity-70" aria-hidden="true">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.3-4.3"></path>
          </svg>
        <span class="max-w-44 truncate pr-3">Search documentation...</span>
        <kbd class="pointer-events-none hidden h-4.5 select-none items-center gap-0.5 rounded border border-border/50 bg-background px-1.5 font-mono text-[9px] font-semibold text-muted-foreground md:inline-flex">
          Ctrl K
        </kbd>
      </button>

      <div class="flex items-center gap-1.5 border-l border-border pl-3.5">
        <ThemeToggle />
        <a
          href="https://github.com/so-sc/pomelo"
          target="_blank"
          rel="noopener noreferrer"
          class="flex h-8 w-8 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
          aria-label="GitHub repository"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</header>

<div id="docs-search-modal" class="fixed inset-0 z-[100] hidden bg-background/80 px-4 py-24 backdrop-blur-md">
  <div class="mx-auto max-w-[44rem] overflow-hidden rounded-lg border border-border bg-popover shadow-lg">
    <div class="border-b border-border p-3">
      <div class="mb-3 flex items-center justify-between gap-3">
        <div class="flex items-center gap-2">
          <span class="rounded-md bg-primary/10 px-2 py-1 text-xs font-medium text-primary">Docs</span>
          <span class="rounded-md bg-muted px-2 py-1 text-xs font-medium text-muted-foreground">Pomelo</span>
        </div>
        <button id="docs-search-close" type="button" class="rounded-md border border-border px-2 py-1 font-mono text-xs text-muted-foreground hover:bg-muted" aria-label="Close search">
          Esc
        </button>
      </div>
      <label class="flex items-center gap-3 rounded-md border border-border bg-background px-3 py-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-muted-foreground" aria-hidden="true">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <input
          id="docs-search"
          type="search"
          autocomplete="off"
          placeholder="What are you searching for?"
          aria-label="Search documentation"
          class="h-8 w-full bg-transparent text-base text-foreground outline-none placeholder:text-muted-foreground"
        />
      </label>
    </div>
    <div id="docs-search-results" class="max-h-[28rem] overflow-y-auto p-2" aria-label="Search results"></div>
  </div>
</div>

<script>
  const searchTrigger = document.querySelector<HTMLButtonElement>("#docs-search-trigger");
  const searchInput = document.querySelector<HTMLInputElement>("#docs-search");
  const searchResults = document.querySelector<HTMLElement>("#docs-search-results");
  const searchModal = document.querySelector<HTMLElement>("#docs-search-modal");
  const searchClose = document.querySelector<HTMLButtonElement>("#docs-search-close");
  const searchItems = [
    { title: "Introduction", group: "Getting Started", href: "#introduction", keywords: "pomelo judge0 contest platform docs overview", description: "Learn what Pomelo is and what this guide covers." },
    { title: "Prerequisites", group: "Getting Started", href: "#prerequisites", keywords: "node pnpm docker git bun requirements install", description: "Check the tools needed before setup." },
    { title: "Installation", group: "Getting Started", href: "#installation", keywords: "clone repository install dependencies pnpm", description: "Clone Pomelo and install workspace dependencies." },
    { title: "Quick Start", group: "Getting Started", href: "#quickstart", keywords: "start services dev scripts endpoints local", description: "Start the local development stack." },
    { title: "Environment Variables", group: "Configuration", href: "#environment", keywords: "env auth secret mongodb judge0 backend url", description: "Set up the root .env file." },
    { title: "Docker Setup", group: "Configuration", href: "#docker", keywords: "docker compose containers mongo judge0 redis postgres", description: "Run the required backing services." },
    { title: "Bun CLI", group: "Admin Tooling", href: "#admin", keywords: "bun admin cli daemon pomelo pomelod", description: "Use the admin CLI and daemon." },
    { title: "Common Issues", group: "Troubleshooting", href: "#troubleshooting", keywords: "troubleshooting pnpm docker mongodb judge0 fails timeout", description: "Fix common setup and runtime issues." },
  ];

  function openSearch() {
    searchModal?.classList.remove("hidden");
    document.body.style.overflow = "hidden";
    renderResults(searchInput?.value ?? "");
    window.setTimeout(() => searchInput?.focus(), 0);
  }

  function closeSearch() {
    searchModal?.classList.add("hidden");
    document.body.style.overflow = "";
    if (searchInput) searchInput.value = "";
  }

  function goToResult(href: string) {
    window.location.hash = href;
    closeSearch();
  }

  function renderResults(query: string) {
    if (!searchResults) return;

    const normalized = query.trim().toLowerCase();
    const matches = (normalized
      ? searchItems.filter((item) => `${item.title} ${item.group} ${item.keywords} ${item.description}`.toLowerCase().includes(normalized))
      : searchItems)
      .slice(0, 6);

    searchResults.innerHTML = "";

    if (!matches.length) {
      const empty = document.createElement("div");
      empty.className = "px-4 py-6 text-sm text-muted-foreground";
      empty.textContent = "No matching docs sections.";
      searchResults.append(empty);
      return;
    }

    matches.forEach((item) => {
      const button = document.createElement("button");
      button.type = "button";
      button.className = "flex w-full items-start gap-3 rounded-md px-3 py-3 text-left hover:bg-muted";
      button.innerHTML = `
        <span class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-md border border-border text-muted-foreground">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
          </svg>
        </span>
        <span class="min-w-0">
          <span class="block text-sm font-semibold text-foreground">${item.title}</span>
          <span class="mt-0.5 block text-xs text-muted-foreground">${item.group} - ${item.description}</span>
        </span>`;
      button.addEventListener("click", () => goToResult(item.href));
      searchResults.append(button);
    });
  }

  searchTrigger?.addEventListener("click", openSearch);
  searchClose?.addEventListener("click", closeSearch);
  searchInput?.addEventListener("input", () => renderResults(searchInput.value));
  searchInput?.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeSearch();
    }

    if (event.key === "Enter") {
      const query = searchInput.value.trim().toLowerCase();
      const match = searchItems.find((item) =>
        `${item.title} ${item.group} ${item.keywords}`.toLowerCase().includes(query),
      );
      if (match) goToResult(match.href);
    }
  });

  document.addEventListener("keydown", (event) => {
    if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === "k") {
      event.preventDefault();
      openSearch();
    }

    if (event.key === "Escape" && !searchModal?.classList.contains("hidden")) {
      closeSearch();
    }
  });

  document.addEventListener("click", (event) => {
    if (!searchModal || searchModal.classList.contains("hidden")) return;
    const target = event.target;
    if (target === searchModal) {
      closeSearch();
    }
  });
</script>
