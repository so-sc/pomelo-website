---
import Logo from "@/components/ui/Logo.astro";
---

<footer class="w-full border-t border-border bg-card/50 py-10">
  <div class="footer-inner">
    <div class="grid grid-cols-1 gap-8 border-b border-border pb-8 md:grid-cols-4">

      <div class="flex flex-col gap-3">
        <Logo />
        <p class="mt-1 max-w-[200px] text-xs leading-relaxed text-muted-foreground">
          Self-hosted competitive programming platform with sandboxed code evaluation via Judge0.
        </p>
      </div>

      <div>
        <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-foreground">Docs</h3>
        <ul class="space-y-2 text-xs">
          <li><a href="/docs#introduction"   class="text-muted-foreground transition-colors hover:text-foreground">Introduction</a></li>
          <li><a href="/docs#installation"   class="text-muted-foreground transition-colors hover:text-foreground">Installation</a></li>
          <li><a href="/docs#environment"    class="text-muted-foreground transition-colors hover:text-foreground">Environment Variables</a></li>
          <li><a href="/docs#docker"         class="text-muted-foreground transition-colors hover:text-foreground">Docker Setup</a></li>
          <li><a href="/docs#troubleshooting" class="text-muted-foreground transition-colors hover:text-foreground">Troubleshooting</a></li>
        </ul>
      </div>

      <div>
        <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-foreground">Community</h3>
        <ul class="space-y-2 text-xs">
          <li><a href="https://github.com/so-sc/pomelo" target="_blank" rel="noopener noreferrer" class="text-muted-foreground transition-colors hover:text-foreground">GitHub</a></li>
          <li><a href="https://github.com/so-sc/pomelo/issues" target="_blank" rel="noopener noreferrer" class="text-muted-foreground transition-colors hover:text-foreground">Issues</a></li>
          <li><a href="https://github.com/so-sc/pomelo/graphs/contributors" target="_blank" rel="noopener noreferrer" class="text-muted-foreground transition-colors hover:text-foreground">Contributors</a></li>
        </ul>
      </div>

      <div>
        <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-foreground">Project</h3>
        <ul class="space-y-2 text-xs">
          <li><a href="https://github.com/so-sc/pomelo?tab=GPL-3.0-1-ov-file" target="_blank" rel="noopener noreferrer" class="text-muted-foreground transition-colors hover:text-foreground">GPL-3.0 License</a></li>
          <li><a href="https://github.com/so-sc/pomelo/releases" target="_blank" rel="noopener noreferrer" class="text-muted-foreground transition-colors hover:text-foreground">Changelog</a></li>
          <li><a href="https://github.com/so-sc/pomelo?tab=contributing-ov-file" target="_blank" rel="noopener noreferrer" class="text-muted-foreground transition-colors hover:text-foreground">Contributing</a></li>
        </ul>
      </div>

    </div>

    <div class="flex flex-col items-center justify-between gap-3 pt-6 text-xs text-muted-foreground sm:flex-row">
      <span>© {new Date().getFullYear()} SOSC · Pomelo</span>
      <span class="text-muted-foreground/60">Released under the GNU General Public License v3.0</span>
    </div>
  </div>
</footer>

<style>
  .footer-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }
  @media (max-width: 860px) {
    .footer-inner {
      padding-left: 1.25rem !important;
      padding-right: 1.25rem !important;
    }
  }
  @media (max-width: 600px) {
    .footer-inner {
      padding-left: 1rem !important;
      padding-right: 1rem !important;
    }
  }
</style>
