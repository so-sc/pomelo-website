---
import { getCollection, render } from "astro:content";
import SectionLabel from "@/components/ui/SectionLabel.astro";
import "@/styles/prose.css";

const guide = await getCollection("guide");
const sortedGuide = guide.sort((a, b) => {
  if (a.data.sectionOrder !== b.data.sectionOrder) {
    return a.data.sectionOrder - b.data.sectionOrder;
  }
  return a.data.order - b.data.order;
});

// Track which sections we've already rendered a label for
const renderedSections = new Set<string>();
---

<main class="min-w-0 flex-1 py-6 pl-0 md:pl-8">
  <div class="prose max-w-[75ch]">
    {
      sortedGuide.map(async (doc) => {
        const { Content } = await render(doc);
        const showSectionLabel = !renderedSections.has(doc.data.section);
        if (showSectionLabel) renderedSections.add(doc.data.section);
        return (
          <section id={doc.id} class="mb-12 scroll-mt-20">
            {showSectionLabel && (
              <SectionLabel>{doc.data.section}</SectionLabel>
            )}
            <Content />
          </section>
        );
      })
    }
  </div>
</main>
