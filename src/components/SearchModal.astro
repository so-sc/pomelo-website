---
import { getCollection } from "astro:content";

const docs = await getCollection("docs");
const guides = await getCollection("guide");

const docsSearchData = docs.map((doc) => ({
  type: "docs",
  title: doc.data.title,
  group: doc.data.section,
  href: `/docs#${doc.id}`,
  keywords: (doc.body || "").toLowerCase(),
  description: (doc.body || "").replace(/<[^>]+>/g, "").replace(/[#*[\]()>\-`]/g, "").replace(/\n/g, " ").slice(0, 60).trim() + "..."
}));

const guidesSearchData = guides.map((doc) => ({
  type: "guide",
  title: doc.data.title,
  group: doc.data.section,
  href: `/guide#${doc.id}`,
  keywords: (doc.body || "").toLowerCase(),
  description: (doc.body || "").replace(/<[^>]+>/g, "").replace(/[#*[\]()>\-`]/g, "").replace(/\n/g, " ").slice(0, 60).trim() + "..."
}));

const searchData = [...docsSearchData, ...guidesSearchData];
---

<div
  id="universal-search-modal"
  data-search-items={JSON.stringify(searchData)}
  class="fixed inset-0 z-[100] hidden h-screen w-screen bg-background/80 px-4 py-24 backdrop-blur-md overflow-y-auto"
>
  <div class="mx-auto max-w-[44rem] overflow-hidden rounded-lg border border-border bg-popover shadow-lg">
    <div class="border-b border-border p-3">
      <div class="mb-3 flex items-center justify-between gap-3">
        <div class="flex items-center gap-2">
          <span class="rounded-md bg-primary/10 px-2 py-1 text-xs font-medium text-primary">Search</span>
          <span class="rounded-md bg-muted px-2 py-1 text-xs font-medium text-muted-foreground">Pomelo</span>
        </div>
        <button id="universal-search-close" type="button" class="rounded-md border border-border px-2 py-1 font-mono text-xs text-muted-foreground hover:bg-muted" aria-label="Close search">
          Esc
        </button>
      </div>
      <label class="flex items-center gap-3 rounded-md border border-border bg-background px-3 py-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-muted-foreground" aria-hidden="true">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <input
          id="universal-search-input"
          type="search"
          autocomplete="off"
          placeholder="Search documentation and guides..."
          aria-label="Search documentation and guides"
          class="h-8 w-full bg-transparent text-base text-foreground outline-none placeholder:text-muted-foreground"
        />
      </label>
    </div>
    <div id="universal-search-results" class="max-h-[28rem] overflow-y-auto p-2" aria-label="Search results"></div>
  </div>
</div>

<script>
  import Fuse from "fuse.js";

  const searchTrigger = document.querySelector<HTMLButtonElement>("#universal-search-trigger");
  const searchInput = document.querySelector<HTMLInputElement>("#universal-search-input");
  const searchResults = document.querySelector<HTMLElement>("#universal-search-results");
  const searchModal = document.querySelector<HTMLElement>("#universal-search-modal");
  const searchClose = document.querySelector<HTMLButtonElement>("#universal-search-close");
  const rawData = searchModal?.dataset.searchItems;
  
  interface SearchItem {
    type: "docs" | "guide";
    title: string;
    group: string;
    href: string;
    keywords: string;
    description: string;
  }
  
  const searchItems: SearchItem[] = rawData ? JSON.parse(rawData) : [];

  const fuse = new Fuse(searchItems, {
    keys: [
      { name: "title", weight: 3 },
      { name: "group", weight: 2 },
      { name: "description", weight: 1.5 },
      { name: "keywords", weight: 1 }
    ],
    threshold: 0.4,
    ignoreLocation: true
  });

  function openSearch() {
    searchModal?.classList.remove("hidden");
    document.body.style.overflow = "hidden";
    renderResults(searchInput?.value ?? "");
    window.setTimeout(() => searchInput?.focus(), 0);
  }

  function closeSearch() {
    searchModal?.classList.add("hidden");
    document.body.style.overflow = "";
    if (searchInput) searchInput.value = "";
  }

  function goToResult(href: string) {
    window.location.href = href;
    closeSearch();
  }

  function renderResults(query: string) {
    if (!searchResults) return;

    const normalized = query.trim();
    let matches: SearchItem[];

    if (normalized) {
      matches = fuse.search(normalized).map(result => result.item).slice(0, 6);
    } else {
      matches = searchItems.slice(0, 6);
    }

    searchResults.innerHTML = "";

    if (!matches.length) {
      const empty = document.createElement("div");
      empty.className = "px-4 py-6 text-sm text-muted-foreground";
      empty.textContent = "No matching results.";
      searchResults.append(empty);
      return;
    }

    matches.forEach((item) => {
      const button = document.createElement("button");
      button.type = "button";
      button.className = "flex w-full items-start gap-3 rounded-md px-3 py-3 text-left hover:bg-muted";
      
      const badgeText = item.type === "docs" ? "Docs" : "Guide";
      const badgeClass = item.type === "docs" 
        ? "bg-sky-500/10 text-sky-600 dark:text-sky-400 border border-sky-500/20" 
        : "bg-purple-500/10 text-purple-600 dark:text-purple-400 border border-purple-500/20";

      button.innerHTML = `
        <span class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-md border border-border text-muted-foreground">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
          </svg>
        </span>
        <span class="min-w-0 flex-1">
          <span class="flex items-center gap-2">
            <span class="block text-sm font-semibold text-foreground">${item.title}</span>
            <span class="rounded px-1.5 py-0.5 text-[10px] font-medium ${badgeClass}">${badgeText}</span>
          </span>
          <span class="mt-0.5 block text-xs text-muted-foreground">${item.group} - ${item.description}</span>
        </span>`;
      button.addEventListener("click", () => goToResult(item.href));
      searchResults.append(button);
    });
  }

  searchTrigger?.addEventListener("click", openSearch);
  searchClose?.addEventListener("click", closeSearch);
  searchInput?.addEventListener("input", () => renderResults(searchInput.value));
  searchInput?.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeSearch();
    }

    if (event.key === "Enter") {
      const query = searchInput.value.trim();
      if (query) {
        const results = fuse.search(query);
        if (results.length > 0) goToResult(results[0].item.href);
      }
    }
  });

  document.addEventListener("keydown", (event) => {
    if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === "k") {
      event.preventDefault();
      openSearch();
    }

    if (event.key === "Escape" && !searchModal?.classList.contains("hidden")) {
      closeSearch();
    }
  });

  document.addEventListener("click", (event) => {
    if (!searchModal || searchModal.classList.contains("hidden")) return;
    const target = event.target;
    if (target === searchModal) {
      closeSearch();
    }
  });
</script>
