---
const sidebarSections = [
  {
    title: "Getting Started",
    links: [
      { label: "Introduction", href: "#introduction" },
      { label: "Prerequisites", href: "#prerequisites" },
      { label: "Installation", href: "#installation" },
      { label: "Quick Start", href: "#quickstart" },
    ],
  },
  {
    title: "Configuration",
    links: [
      { label: "Environment Variables", href: "#environment" },
      { label: "Docker Setup", href: "#docker" },
    ],
  },
  {
    title: "Admin Tooling",
    links: [{ label: "Bun CLI", href: "#admin" }],
  },
  {
    title: "Troubleshooting",
    links: [{ label: "Common Issues", href: "#troubleshooting" }],
  },
];
---

<aside class="sticky top-14 hidden h-[calc(100vh-3.5rem)] w-56 shrink-0 overflow-y-auto border-r border-border md:block">
  <div class="py-6 pr-4">
    {sidebarSections.map((section) => (
      <div class="mb-4">
        <p class="mb-1 px-3 text-xs font-semibold text-foreground">{section.title}</p>
        <ul>
          {section.links.map((link) => (
            <li>
              <a
                href={link.href}
                class="block rounded-md px-3 py-1 text-sm text-muted-foreground hover:bg-muted hover:text-foreground"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</aside>
