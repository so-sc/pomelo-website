---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Hero from "@/components/landing/Hero.astro";
import Features from "@/components/landing/Features.astro";
import QuickStart from "@/components/landing/QuickStart.astro";

const installCommand = `curl -fsSL pomelo.sosc.org.in/install.sh | sudo bash`;
---

<Layout title="Pomelo | Open-source Contest Platform">
  <div class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1">
      <Hero installCommand={installCommand} />
      <Features />
      <QuickStart />
    </main>
    <Footer />
  </div>
</Layout>
